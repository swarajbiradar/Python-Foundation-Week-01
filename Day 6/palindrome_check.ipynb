    "def is_palindrome(s):\n",
    "    return s == s[::-1]\n",
    "\n",
    "word = \"radar\"\n",
    "print(\"Word:\", word)\n",
    "print(\"Is Palindrome?\", is_palindrome(word))"
   ]
