   "source": [
    "def sum_of_array(arr):\n",
    "    total = 0\n",
    "    for num in arr:\n",
    "        total += num\n",
    "    return total\n",
    "\n",
    "numbers = [2, 5, 7, 10, 3]\n",
    "print(\"Array:\", numbers)\n",
    "print(\"Sum of array elements:\", sum_of_array(numbers))"
   ]
  }
